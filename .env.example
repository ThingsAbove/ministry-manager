DEBUG=True
SECRET_KEY=change-me-in-production
DATABASE_URL=postgres://ministry:ministry@localhost:5432/ministry_manager
# Superuser connection used only by `manage.py create_db` for local setup
DATABASE_ADMIN_URL=postgres://postgres:postgres@localhost:5432/postgres
REDIS_URL=redis://localhost:6379/0
# Celery: leave unset for local non-Docker dev (uses PostgreSQL via DATABASE_URL).
# Docker Compose sets CELERY_BROKER_URL to Redis automatically.
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/0
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

CHURCH_NAME=My Church
CHURCH_TIMEZONE=America/New_York

EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=noreply@example.com
TEST_EMAIL_ADDRESS=dev@hamradioqrp.com

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_FROM_NUMBER=

REMINDER_DAYS_BEFORE=7,1
